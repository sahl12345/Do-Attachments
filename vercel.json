{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm --filter @workspace/api-server run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x",
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ]
}
