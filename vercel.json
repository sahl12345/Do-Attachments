{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/mobile exec expo export --platform web",
  "outputDirectory": "artifacts/mobile/dist",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x",
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
